# .gitignore - Ecopark Mundo de Colores

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Node modules (si usas npm en futuro)
node_modules/
npm-debug.log
package-lock.json

# Build outputs
dist/
build/
*.min.js
*.min.css

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Temp files
*.tmp
*.temp
~*.docx

# Cache
.cache/
.vuepress/dist/
.nuxt/
.next/
out/

# Production
.vercel
.netlify

# Private files
private/
secrets/
credentials.json

# Backup files
*.backup
*.bak
old/
archive/

# IDE configs (optional - keep for team)
# .vscode/
# .idea/
